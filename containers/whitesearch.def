# WhiteSearch Apptainer / Singularity definition file
# For HPC clusters that use Apptainer instead of Docker.
#
# Build: apptainer build whitesearch.sif whitesearch.def
# Run:   apptainer exec whitesearch.sif whitesearch --help

Bootstrap: docker
From: python:3.11-slim-bookworm

%labels
    Author WhiteSearch Team
    Version 0.1.0
    Description White hole candidate signal search engine

%environment
    export PATH=/opt/whitesearch/bin:$PATH
    export PYTHONPATH=/opt/whitesearch/src:$PYTHONPATH
    export MPLBACKEND=Agg
    export OMP_NUM_THREADS=1

%post
    apt-get update && apt-get install -y --no-install-recommends \
        gcc gfortran libfftw3-dev libhdf5-dev libgsl-dev \
        libopenblas-dev liblapack-dev git wget curl \
        && rm -rf /var/lib/apt/lists/*

    pip install --no-cache-dir --upgrade pip setuptools wheel

    pip install --no-cache-dir \
        numpy>=1.26 scipy>=1.12 matplotlib>=3.8 \
        astropy>=6.0 astroquery>=0.4.7 pydantic>=2.6 \
        h5py>=3.10 pandas>=2.2 PyYAML>=6.0 click>=8.1 \
        tqdm>=4.66 scikit-learn>=1.4 corner>=2.2

    pip install --no-cache-dir bilby>=2.2 dynesty>=2.1 || true
    pip install --no-cache-dir gwpy>=3.0 || true
    pip install --no-cache-dir pycbc>=2.3 || true
    pip install --no-cache-dir einsteinpy>=0.4 || true
    pip install --no-cache-dir ehtim>=1.2 || true
    pip install --no-cache-dir mlflow>=2.11 dvc>=3.48 joblib>=1.3 || true

    mkdir -p /opt/whitesearch

%files
    src /opt/whitesearch/src
    pyproject.toml /opt/whitesearch/pyproject.toml
    README.md /opt/whitesearch/README.md
    configs /opt/whitesearch/configs
    workflows /opt/whitesearch/workflows

%post
    cd /opt/whitesearch && pip install --no-cache-dir -e "." || true

%runscript
    exec whitesearch "$@"

%test
    python -c "import whitesearch; print('WhiteSearch', whitesearch.__version__, 'OK')"
    whitesearch --help
